  <text>
    <body>
      <p>TEI for manuscript description</p>
      <schemaSpec ident="tei_mb" start="TEI teiCorpus" prefix="tei_" targetLang="en" docLang="en">
        <moduleRef key="header"/>
        <moduleRef key="linking"/>
        <moduleRef key="core"/>
        <moduleRef key="corpus" include="particDesc"/>
        <moduleRef key="tei"/>
        <moduleRef key="textstructure"
          except="argument back byline closer div1 div2 div3 div4 div5 div6 div7 docAuthor docDate docEdition docImprint docTitle epigraph floatingText front group imprimatur opener postscript salute signed titlePage titlePart trailer"/>
        <moduleRef key="namesdates"
          except="affiliation langKnowledge langKnown listEvent listNym listObject nationality nym object objectIdentifier objectName occupation offset persona region residence settlement sex socecStatus state terrain trait"/>
        <moduleRef key="transcr"
          except="addSpan am ex facsimile line listTranspose path redo restore retrace secl sourceDoc subst substJoin surface surfaceGrp surplus transpose undo zone"/>
        <moduleRef key="figures"/>
        <moduleRef key="msdescription"
          except="accMat acquisition additional altIdentifier binding bindingDesc catchwords collation colophon condition custEvent custodialHist decoDesc decoNote depth dim dimensions explicit filiation finalRubric foliation height heraldry history incipit institution layout layoutDesc msItemStruct msName msPart musicNotation objectDesc objectType provenance recordHist rubric scriptDesc seal sealDesc secFol signatures stamp summary support supportDesc surrogates typeDesc typeNote watermark width"/>
        <elementSpec ident="div" mode="change">
          <attList>
            <attDef ident="change" mode="delete"/>
            <attDef ident="cert" mode="delete"/>
            <attDef ident="resp" mode="delete"/>
            <attDef ident="ana" mode="delete"/>
            <attDef ident="org" mode="delete"/>
            <attDef ident="sample" mode="delete"/>
            <attDef ident="type" mode="change">
              <valList type="semi" mode="change"/>
            </attDef>
            <attDef ident="decls" mode="delete"/>
            <attDef ident="met" mode="delete"/>
            <attDef ident="real" mode="delete"/>
            <attDef ident="rhyme" mode="delete"/>
            <attDef ident="part" mode="delete"/>
            <attDef ident="facs" mode="delete"/>
            <attDef ident="select" mode="delete"/>
            <attDef ident="exclude" mode="delete"/>
            <attDef ident="corresp" mode="delete"/>
            <attDef ident="synch" mode="delete"/>
            <attDef ident="sameAs" mode="delete"/>
            <attDef ident="copyOf" mode="delete"/>
            <attDef ident="next" mode="delete"/>
            <attDef ident="prev" mode="delete"/>
            <attDef ident="xml:space" mode="delete"/>
            <attDef ident="xml:base" mode="delete"/>
          </attList>
        </elementSpec>
        <elementSpec ident="handShift" mode="change">
          <attList>
            <attDef ident="new" mode="change">
              <valList mode="change" type="semi">
                <valItem mode="add" ident="#h1">
                  <desc versionDate="2023-10-11" xml:lang="en">black ink</desc>
                </valItem>
                <valItem mode="add" ident="#h2">
                  <desc versionDate="2023-10-11" xml:lang="en">red ink</desc>
                </valItem>
              </valList>
            </attDef>
          </attList>
        </elementSpec>
        <elementSpec ident="pb" mode="change">
          <classes mode="change">
            <memberOf key="att.breaking" mode="delete"/>
            <memberOf key="att.edition" mode="delete"/>
            <memberOf key="att.spanning" mode="delete"/>
            <memberOf key="att.typed" mode="delete"/>
          </classes>
          <attList>
            <attDef ident="xml:lang" mode="delete"/>
            <attDef ident="xml:base" mode="delete"/>
            <attDef ident="xml:space" mode="delete"/>
            <attDef ident="rend" mode="delete"/>
            <attDef ident="style" mode="delete"/>
            <attDef ident="rendition" mode="delete"/>
            <attDef ident="corresp" mode="delete"/>
            <attDef ident="synch" mode="delete"/>
            <attDef ident="sameAs" mode="delete"/>
            <attDef ident="copyOf" mode="delete"/>
            <attDef ident="next" mode="delete"/>
            <attDef ident="prev" mode="delete"/>
            <attDef ident="exclude" mode="delete"/>
            <attDef ident="select" mode="delete"/>
            <attDef ident="change" mode="delete"/>
            <attDef ident="cert" mode="delete"/>
            <attDef ident="resp" mode="delete"/>
            <attDef ident="source" mode="delete"/>
            <attDef ident="ana" mode="delete"/>
          </attList>
        </elementSpec>
        <elementSpec ident="persName" mode="change">
          <attList>
            <attDef ident="ref" mode="change">
              <valList type="semi" mode="change">
                <valItem mode="add" ident="#MB">
                  <desc versionDate="2023-10-11" xml:lang="en">Mary Behrend</desc>
                </valItem>
                <valItem mode="add" ident="#SP">
                  <desc versionDate="2023-10-11" xml:lang="en">St. Patrick</desc>
                </valItem>
                <valItem mode="add" ident="#MW">
                  <desc versionDate="2023-10-11" xml:lang="en">Mr. Weir</desc>
                </valItem>
                <valItem mode="add" ident="#EB">
                  <desc versionDate="2023-10-11" xml:lang="en">Ernst Behrend</desc>
                </valItem>
                <valItem mode="add" ident="#RC">
                  <desc versionDate="2023-10-11" xml:lang="en">Reece Cullen, student from the future
                    who gets in time machine and travels to 1909.</desc>
                </valItem>
              </valList>
            </attDef>
          </attList>
        </elementSpec>
      </schemaSpec>
    </body>
  </text>
</TEI>
