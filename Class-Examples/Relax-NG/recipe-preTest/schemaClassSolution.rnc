# SUBMITTING YOUR EXAM:
# When you are finished, upload BOTH the schema and the XML file to Canvas using the posted upload point for this exam. 
# You may zip the files to submit them just as you have done for homework assignments.

start = xml
xml = element xml {metadata, recipe}
metadata = element metadata {title, author, editor, source, time, yield} # ebb 5: Add yield to the content model

yield = element yield {text} # ebb 6: Add rule for yield
title = element title {text} # ebb 1: corrected typo for reserve word text
author = element author {id, text}
editor = element editor {id, text}
source = element source {url, text} # ebb 4: added url to content model of source
time = element time {dur, text}
id = attribute id {xsd:ID} # ebb 3: Associated schema, fixed name of attribute from is to id
url = attribute url {xsd:anyURI}
dur = attribute dur {xsd:duration}
recipe = element recipe {ingList, prep}
ingList = element ingList {heading, ing+}
heading = element heading {text}
ing = element ing {id, meas?, unit?, mixed{alt*}}
alt = element alt {meas, unit, text}
meas = attribute meas {xsd:float}
unit = attribute unit {"cup" | "T" | "t"  | "F" | "C" | "inch" | "pint"}
# ebb 12: added missing attribute option
prep = element prep {heading, step+} # ebb 8: Corrected repetition indicator
step = element step {n, mixed{(combine | equip | equipUse | ingUse)+}}
  # ebb 10: corrected mixed syntax with parenthetical grouping


equip = element equip {id, mixed{(temp | equip | equipUse | size | setting | time)*}} # ebb 9: Added temp to content model
# add size to content model of equip
setting = element setting {text} # ebb 2: Added missing rule for element setting
temp = element temp {meas, unit, text}
size = element size {depth, unit, text}
depth = attribute depth {xsd:float}
equipUse = element equipUse {ref, mixed{(temp | size | equip | equipUse | ingUse | setting | time)*}}
ingUse = element ingUse {ref, meas?, unit?, text} # ebb 13: Added repetition indicator of ? to make this optional 
ref = attribute ref {xsd:IDREFS}
combine = element combine {ref, mixed{ingUse*}} # ebb: added mixed syntax with zero or more ingUse possibility
n = attribute n {xsd:int} # ebb 7: corrected datatype to xsd:int (or xsd:integer would work)










